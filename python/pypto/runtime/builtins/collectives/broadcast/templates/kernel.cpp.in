extern "C" __aicore__ __attribute__((always_inline)) void kernel_entry(__gm__ int64_t *args) {
  __gm__ Tensor *target_tensor = reinterpret_cast<__gm__ Tensor *>(args[0]);
  __gm__ Tensor *signal_tensor = reinterpret_cast<__gm__ Tensor *>(args[1]);
  int nranks = static_cast<int>(args[2]);
  __gm__ CommContext *comm_ctx = reinterpret_cast<__gm__ CommContext *>(args[3]);

  int64_t numel = 1;
  for (uint32_t dim = 0; dim < target_tensor->ndims; ++dim) {
    numel *= static_cast<int64_t>(target_tensor->shapes[dim]);
  }

  __gm__ {{dtype_cpp}} *target =
      reinterpret_cast<__gm__ {{dtype_cpp}} *>(target_tensor->buffer.addr) + target_tensor->start_offset;
  __gm__ int32_t *signal_base =
      reinterpret_cast<__gm__ int32_t *>(signal_tensor->buffer.addr) + signal_tensor->start_offset;

  if (nranks <= 0 || nranks > kMaxSupportedRanks || kRoot < 0 || kRoot >= nranks || numel <= 0) {
    pipe_barrier(PIPE_ALL);
    return;
  }

  int my_rank = static_cast<int>(comm_ctx->rankId);

  using ShapeDyn = pto::Shape<pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC>;
  using StrideDyn = pto::Stride<pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC, pto::DYNAMIC>;
  using Global = pto::GlobalTensor<{{dtype_cpp}}, ShapeDyn, StrideDyn, pto::Layout::ND>;
  using TileData = pto::Tile<pto::TileType::Vec, {{dtype_cpp}}, 1, kTileCount, pto::BLayout::RowMajor, -1, -1>;

  TileData stage_tile(1, kTileCount);
  TileData recv_tile(1, kTileCount);
  TASSIGN(stage_tile, 0x0);
  TASSIGN(recv_tile, 0x10000);

  // Signal scheme: each slot is single-writer (rank j writes into my_rank's
  // signal[j]). TNOTIFY adds a constant 1 per tile; the TWAIT threshold grows
  // 1, 2, 3, … because TWAIT(GE) is non-consuming — the slot retains its
  // accumulated value across tiles. This matches the reduce_scatter signal
  // protocol (constant notify + incrementing wait threshold).
  int32_t expected = 1;
  for (int64_t base = 0; base < numel; base += kTileCount) {
    int64_t chunk64 = numel - base;
    if (chunk64 > kTileCount) chunk64 = kTileCount;
    int chunk = static_cast<int>(chunk64);

    ShapeDyn shape(1, 1, 1, 1, chunk);
    StrideDyn stride(chunk, chunk, chunk, chunk, 1);
    Global target_g(target + base, shape, stride);

    if (my_rank == kRoot) {
      TLOAD(stage_tile, target_g);
      set_flag(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
      wait_flag(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
      TSTORE(target_g, stage_tile);
      set_flag(PIPE_MTE3, PIPE_MTE2, EVENT_ID0);
      wait_flag(PIPE_MTE3, PIPE_MTE2, EVENT_ID0);
    }
    pipe_barrier(PIPE_ALL);

    for (int peer = 0; peer < nranks; ++peer) {
      if (peer == my_rank) continue;
      __gm__ int32_t *remote_signal = CommRemotePtr(comm_ctx, signal_base + my_rank, peer);
      pto::comm::Signal sig(remote_signal);
      pto::comm::TNOTIFY(sig, static_cast<int32_t>(1), pto::comm::NotifyOp::AtomicAdd);
    }
    for (int peer = 0; peer < nranks; ++peer) {
      if (peer == my_rank) continue;
      pto::comm::Signal sig(signal_base + peer);
      pto::comm::TWAIT(sig, expected, pto::comm::WaitCmp::GE);
    }
    ++expected;
    pipe_barrier(PIPE_ALL);

    if (my_rank != kRoot) {
      __gm__ {{dtype_cpp}} *root_target = CommRemotePtr(comm_ctx, target + base, kRoot);
      Global root_g(root_target, shape, stride);
      TLOAD(recv_tile, root_g);
      set_flag(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
      wait_flag(PIPE_MTE2, PIPE_MTE3, EVENT_ID0);
      TSTORE(target_g, recv_tile);
      set_flag(PIPE_MTE3, PIPE_MTE2, EVENT_ID0);
      wait_flag(PIPE_MTE3, PIPE_MTE2, EVENT_ID0);
    }
  }

  pipe_barrier(PIPE_ALL);
}
